{
  // ── GitHub Copilot — Discovery de agentes, instrucciones y prompts ──────────
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.followUps": "always",
  "github.copilot.nextEditSuggestions.enabled": true,

  // Activa la aplicación automática de archivos .instructions.md
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,

  // Activa agentes customizados (.agent.md) y prompt files (.prompt.md)
  "chat.agent.enabled": true,
  "chat.promptFiles.enabled": true,

  // ── Explorador de archivos — ocultar temporales personales ──────────────────
  "files.exclude": {
    "config/active-profile.json": true,
    "config/active-workflow.json": true,
    "tmp/": true,
    "tools/*.jar": true
  },

  // ── Editor ──────────────────────────────────────────────────────────────────
  "editor.formatOnSave": false,
  "files.associations": {
    "restricciones_sprint": "plaintext",
    "restricciones_sprint.template": "plaintext",
    "*.agent.md": "markdown",
    "*.prompt.md": "markdown",
    "*.instructions.md": "markdown"
  }
}
