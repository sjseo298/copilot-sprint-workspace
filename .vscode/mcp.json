{
  "servers": {
    "azure-devops": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-e", "AZURE_DEVOPS_ORG",
        "-e", "AZURE_DEVOPS_PAT",
        "sjseo298/mcp-azure-devops"
      ],
      "env": {
        "AZURE_DEVOPS_ORG": "${env:AZURE_DEVOPS_ORGANIZATION}",
        "AZURE_DEVOPS_PAT": "${env:AZURE_DEVOPS_PAT}"
      }
    }
  }
}
